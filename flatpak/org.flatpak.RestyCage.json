{
	"id": "org.flatpak.RestyCage",
	"runtime": "org.kde.Platform",
	"runtime-version": "6.10",
	"sdk": "org.kde.Sdk",
	"command": "RestyCage",
	"finish-args":[
		"--share=ipc",
		"--socket=fallback-x11",
		"--socket=wayland",
		"--device=dri",
		"--share=network",
		"--filesystem=home"
 	],
	"modules":[
 		{
 			"name": "RestyCage",
 			"buildsystem": "cmake-ninja",
 			"builddir": true,
 			"config-opts": [
				"-DCMAKE_BUILD_TYPE=Release"
		      	],
		 	"sources": [
 				{
 					"type": "git",
 					"url": "https://github.com/apogza/RestyCage.git"
 				}
 			]
 		}
 	]
}
 
	

